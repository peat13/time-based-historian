# ==================================================================================================
# Timebase Infrastructure - Environment Configuration
# ==================================================================================================
#
# 🎯 GETTING STARTED:
#   1. Copy this file to .env:  cp example.env .env
#   2. Customize any values you need (optional - defaults work!)
#   3. Run: docker-compose up -d
#
# 💡 TIP: You don't need to uncomment or change anything if the defaults work for you.
#         Only customize what you need!
#
# ==================================================================================================

# --------------------------------------------------------------------------------------------------
# 🏷️  Image Tags - Control which version to use
# --------------------------------------------------------------------------------------------------
# Use 'latest' for the newest version, or specify a version like 'v1.2.3' for stability
# See available tags at: https://hub.docker.com/u/timebase
# --------------------------------------------------------------------------------------------------

# HISTORIAN_TAG=latest
# COLLECTOR_TAG=latest
# EXPLORER_TAG=latest

# --------------------------------------------------------------------------------------------------
# 🌐 Network Configuration
# --------------------------------------------------------------------------------------------------

# NETWORK_NAME=timebase-network

# --------------------------------------------------------------------------------------------------
# 📦 Timebase Historian Configuration
# --------------------------------------------------------------------------------------------------

# HISTORIAN_CONTAINER_NAME=historian
# HISTORIAN_HOSTNAME=historian
# HISTORIAN_PORT=4511
# HISTORIAN_VOLUME_NAME=timebase-historian-data

# --------------------------------------------------------------------------------------------------
# 🎨 Timebase Explorer Configuration
# --------------------------------------------------------------------------------------------------

# EXPLORER_CONTAINER_NAME=explorer
# EXPLORER_HOSTNAME=explorer
# EXPLORER_PORT=4531
# EXPLORER_VOLUME_NAME=timebase-explorer-data

# --------------------------------------------------------------------------------------------------
# 🔌 Timebase Collector 01 Configuration
# --------------------------------------------------------------------------------------------------

# COLLECTOR_01_ACTIVE=false
# COLLECTOR_01_CONTAINER_NAME=collector-01
# COLLECTOR_01_HOSTNAME=collector-01
# COLLECTOR_01_PORT=4521
# COLLECTOR_01_VOLUME_NAME=timebase-collector-01-data

# ==================================================================================================
# 💡 COMMON CUSTOMIZATIONS
# ==================================================================================================
#
# 🔒 Use specific versions instead of 'latest':
#    HISTORIAN_TAG=v2.1.0
#    COLLECTOR_TAG=v2.1.0
#    EXPLORER_TAG=v2.1.0
#
# 🔌 Use different ports (if default ports are taken):
#    HISTORIAN_PORT=5511
#    EXPLORER_PORT=5531
#    COLLECTOR_01_PORT=5521
#
# 📍 Custom volume names:
#    HISTORIAN_VOLUME_NAME=my-historian-data
#    COLLECTOR_01_VOLUME_NAME=my-collector-01-data
#    EXPLORER_VOLUME_NAME=my-explorer-data
#
# 🌐 Custom network name:
#    NETWORK_NAME=my-timebase-network
#
# ==================================================================================================
# 🎓 ADVANCED: Adding Multiple Collectors
# ==================================================================================================
#
# To add a second collector:
#   1. Uncomment the timebase-collector-02 service in docker-compose.yml (Services section)
#   2. Uncomment the collector-02-data volume in docker-compose.yml (Volumes section)
#   3. Optionally customize these variables below
#   4. Run: docker-compose up -d
#
# The second collector will be available at http://localhost:4522
#
# --------------------------------------------------------------------------------------------------
# 🔌 Collector 02 Configuration (Optional)
# --------------------------------------------------------------------------------------------------
#
# Uncomment these if you're adding a second collector and want to customize it:
#
# COLLECTOR_02_ACTIVE=false
# COLLECTOR_02_CONTAINER_NAME=collector-02
# COLLECTOR_02_HOSTNAME=collector-02
# COLLECTOR_02_PORT=4522
# COLLECTOR_02_VOLUME_NAME=timebase-collector-02-data
#
# --------------------------------------------------------------------------------------------------
# 🔌 Collector 03 Configuration (Optional)
# --------------------------------------------------------------------------------------------------
#
# Uncomment these if you're adding a third collector and want to customize it:
#
# COLLECTOR_03_ACTIVE=false
# COLLECTOR_03_CONTAINER_NAME=collector-03
# COLLECTOR_03_HOSTNAME=collector-03
# COLLECTOR_03_PORT=4523
# COLLECTOR_03_VOLUME_NAME=timebase-collector-03-data
#
# ==================================================================================================
